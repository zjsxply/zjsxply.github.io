---
layout: default
---
{% assign current_lang = page.lang | default: site.lang | split: '-' | first %}
{% assign wechat_title_label = 'WeChat ID:' %}
{% assign wechat_hint_label = 'Click to copy' %}
{% assign wechat_copied_label = 'Copied!' %}
{% assign wechat_failed_label = 'Copy failed — please copy manually.' %}
{% assign wechat_close_label = 'Close WeChat dialog' %}
{% if current_lang == 'zh' %}
  {% assign news_label = '🗞️ 动态' %}
  {% assign wechat_title_label = '微信号：' %}
  {% assign wechat_hint_label = '点击复制' %}
  {% assign wechat_copied_label = '已复制！' %}
  {% assign wechat_failed_label = '复制失败，请手动复制。' %}
  {% assign wechat_close_label = '关闭微信弹窗' %}
  {% assign news_url = '/zh/news/' %}
  {% assign publications_label = '📚 代表论文' %}
  {% assign publications_url = '/zh/publications/' %}
{% else %}
  {% assign news_label = '🗞️ news' %}
  {% assign news_url = '/news/' %}
  {% assign publications_label = '📚 selected publications' %}
  {% assign publications_url = '/publications/' %}
{% endif %}
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if page.display_name %}
        {{ page.display_name }}
      {% elsif site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    {% if page.subtitle %}
      <p class="desc">{{ page.subtitle }}</p>
    {% endif %}
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ news_url | relative_url }}" style="color: inherit">{{ news_label }}</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ publications_url | relative_url }}" style="color: inherit">{{ publications_label }}</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    {% if page.home_sections %}
      {% include home_sections.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        {% if site.contact_note %}
          <div class="contact-note">{{ site.contact_note }}</div>
        {% endif %}
      </div>

      {% if site.data.socials.wechat.id %}
        <div id="wechat-modal" class="wechat-modal" role="dialog" aria-modal="true" aria-labelledby="wechat-modal-title" aria-hidden="true">
          <div class="wechat-modal__dialog" role="document">
            <button type="button" class="wechat-modal__close" aria-label="{{ wechat_close_label }}">&times;</button>
            <button
              type="button"
              class="wechat-modal__copy"
              data-copy-text="{{ site.data.socials.wechat.id }}"
              data-copy-hint="{{ wechat_hint_label }}"
              data-copy-success="{{ wechat_copied_label }}"
              data-copy-failed="{{ wechat_failed_label }}"
            >
              <span id="wechat-modal-title">{{ wechat_title_label }}</span>
              <strong>{{ site.data.socials.wechat.id }}</strong>
            </button>
            <button type="button" class="wechat-modal__hint" aria-live="polite">{{ wechat_hint_label }}</button>
          </div>
        </div>
      {% endif %}
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
